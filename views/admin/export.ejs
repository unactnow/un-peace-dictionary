<%- include('../partials/admin-head') %>

<h2>Export HTML</h2>
<p><strong><%= termCount %></strong> term(s) ready for export. <span class="hint">Generated at <%= new Date(generatedAt).toLocaleString() %></span></p>
<div class="btn-row" style="justify-content: space-between;">
    <div style="display:flex; gap:0.75rem; align-items:center;">
        <button type="button" class="btn" id="copy-btn">Copy to clipboard</button>
        <a class="btn btn-outline" href="/export/download">Download HTML</a>
    </div>
    <a href="/admin/terms">&larr; Back to terms list</a>
</div>

<h3>Instructions</h3>
<p>Copy and paste this code into the editor on the <a href="https://un.org/en/peaceandsecurity/peace-dictionary/" target="_blank" rel="noopener">Peace Dictionary</a> page. Ensure the editor is in <strong>Source mode</strong> and delete all existing code before pasting the new code.</p>
<pre class="export-pre"><code id="export-code"><%= htmlOutput %></code></pre>

<textarea id="export-raw" hidden aria-hidden="true"><%- htmlOutput %></textarea>

<script>
(function () {
  var raw = document.getElementById('export-raw');
  var btn = document.getElementById('copy-btn');
  if (!raw || !btn) return;
  btn.addEventListener('click', function () {
    navigator.clipboard.writeText(raw.value).then(function () {
      btn.textContent = 'Copied!';
      setTimeout(function () { btn.textContent = 'Copy to clipboard'; }, 2000);
    });
  });
})();
</script>

<style>
.export-pre {
  font-family: ui-monospace, "SF Mono", monospace;
  font-size: 0.8125rem;
  line-height: 1.6;
  max-height: 75vh;
  overflow: auto;
  background: #f8f9fa;
  color: var(--color-text);
  padding: 1.25rem 1.5rem;
  border-radius: var(--radius);
  white-space: pre-wrap;
  word-break: break-word;
  margin-top: 0.5rem;
  border: 1px solid var(--color-border);
}
.export-pre code { font-family: inherit; font-size: inherit; }
</style>

<%- include('../partials/admin-footer') %>
