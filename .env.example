# Database (Neon PostgreSQL — app data: terms, settings, sessions, …)
DATABASE_URL=

# Shared users + password_reset_tokens (same in un-social-feed, un-story-builder, un-peace-dictionary).
# Omit to keep users on DATABASE_URL (legacy).
# AUTH_DATABASE_URL=

# Session
SESSION_SECRET=your-super-secret-session-key-change-in-production

# App
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# SMTP (leave blank to log reset URLs to console instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Seed script (used by npm run seed)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin
